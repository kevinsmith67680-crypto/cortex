# Copy this file to .env and fill in your key:  cp .env.example .env
# Never commit your real .env — it's git-ignored.

# Required: your Anthropic API key (https://console.anthropic.com/ → Settings → API keys)
ANTHROPIC_API_KEY=

# Optional: the model used to generate quizzes.
# Your current default is claude-sonnet-4-5; claude-sonnet-4-6 is the newer Sonnet
# and is worth moving to before launch so a deprecation can't break quizzes.
ANTHROPIC_MODEL=claude-sonnet-4-5

# Optional: server port (defaults to 3000)
PORT=3000

# Optional: per-IP quiz caps (defaults 10 / 40)
RATE_HOURLY=10
RATE_DAILY=40

# Optional: RevenueCat webhook shared secret. When set, the server trusts ONLY
# entitlements confirmed by RevenueCat (the client's claimed tier is ignored).
# Use any long random string and paste the same value as the Authorization header
# in RevenueCat → Project settings → Webhooks. Leave blank for local/test mode.
RC_WEBHOOK_AUTH=
